  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^26.0.0",
    "typescript": "^6.0.3",
    "vite-plus": "0.1.21"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "onesignal",
    "push",
    "notification",
    "push notification",
    "react"
  ],
  "packageManager": "bun@1.3.13"
}
